# ─── Database Connection ─────────────────────────────────────
# For local development with MySQL running natively:
# DATABASE_URL="mysql://root:YOUR_PASSWORD@localhost:3306/startup_ecosystem"
#
# For local development with Docker (see docker-compose.yml):
# DATABASE_URL="mysql://root:startup123@localhost:3307/startup_ecosystem"
#
# For production with connection pooling (recommended):
# DATABASE_URL="mysql://USER:PASSWORD@HOST:3306/startup_ecosystem?connection_limit=20&pool_timeout=10&connect_timeout=10"
DATABASE_URL="mysql://root:YOUR_PASSWORD@localhost:3306/startup_ecosystem"
