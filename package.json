{
  "name": "startup-ecosystem",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "clean": "turbo run clean",
    "db:generate": "turbo run db:generate --filter=@startup-ecosystem/db",
    "db:migrate": "turbo run db:migrate --filter=@startup-ecosystem/db",
    "db:migrate:deploy": "turbo run db:migrate:deploy --filter=@startup-ecosystem/db",
    "db:push": "turbo run db:push --filter=@startup-ecosystem/db",
    "db:studio": "npm run db:studio --workspace=packages/db",
    "db:seed": "npm run db:seed --workspace=packages/db",
    "db:reset": "npm run db:reset --workspace=packages/db",
    "db:validate": "npm run db:validate --workspace=packages/db",
    "postinstall": "npm run db:generate --workspace=packages/db"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.3"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Rishit1769/Digital-Platform-for-Startup-Ecosystem.git"
  },
  "license": "ISC",
  "packageManager": "npm@11.9.0"
}
