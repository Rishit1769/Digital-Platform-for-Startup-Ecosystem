{
  "name": "startup-ecosystem",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "preinstall": "node -e \"if(process.platform !== 'win32') { try { require('child_process').execSync('pgrep -f node | grep -v ' + process.pid + ' | xargs kill -9 || true'); } catch(e){} }\"",
    "build": "NODE_OPTIONS=\"--max-old-space-size=4096\" turbo run build",
    "start": "turbo run start --filter=frontend --filter=@startup-ecosystem/backend",
    "start:frontend": "npm run start --workspace=frontend",
    "start:backend": "npm run start --workspace=@startup-ecosystem/backend",
    "lint": "turbo run lint",
    "clean": "turbo run clean",
    "db:generate": "turbo run db:generate --filter=@startup-ecosystem/db",
    "db:migrate": "turbo run db:migrate --filter=@startup-ecosystem/db",
    "db:migrate:deploy": "turbo run db:migrate:deploy --filter=@startup-ecosystem/db",
    "db:push": "turbo run db:push --filter=@startup-ecosystem/db",
    "db:studio": "npm run db:studio --workspace=packages/db",
    "db:seed": "npm run db:seed --workspace=packages/db",
    "db:reset": "npm run db:reset --workspace=packages/db",
    "db:validate": "npm run db:validate --workspace=packages/db",
    "postinstall": "npm run db:generate --workspace=packages/db",
    "dev": "turbo run dev"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.3"
  },
  "optionalDependencies": {
    "lightningcss-linux-x64-gnu": "^1.22.0",
    "@tailwindcss/oxide-linux-x64-gnu": "*"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Rishit1769/Digital-Platform-for-Startup-Ecosystem.git"
  },
  "license": "ISC",
  "packageManager": "npm@11.9.0"
}
